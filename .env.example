# ============================================================
# GitLab Workspaces 설치 환경 변수 설정
# GitLab 18.9 기준
# ============================================================
# 이 파일을 복사하여 .env 파일을 생성하고 값을 채워주세요.
# cp .env.example .env
# ============================================================

# ----------------------------------------
# GitLab 설정
# ----------------------------------------
# GitLab 인스턴스 URL (예: https://gitlab.example.com)
GITLAB_URL="https://gitlab.example.com"

# GitLab Personal Access Token
# 필요 권한: api, read_repository, write_repository, admin_mode (관리자 계정 권장)
GITLAB_TOKEN="glpat-xxxxxxxxxxxxxxxxxxxx"

# GitLab Agent를 등록할 프로젝트 경로 (예: group/project)
GITLAB_PROJECT_PATH="your-group/your-project"

# GitLab Agent 이름 (Kubernetes에서 사용할 이름, 영문 소문자/숫자/-만 허용)
GITLAB_AGENT_NAME="workspaces-agent"

# ----------------------------------------
# Kubernetes 네임스페이스 설정
# ----------------------------------------
# GitLab Agent를 설치할 Kubernetes 네임스페이스
GITLAB_AGENT_NAMESPACE="gitlab-agent"

# Workspaces Proxy를 설치할 네임스페이스
WORKSPACES_PROXY_NAMESPACE="gitlab-workspaces"

# ----------------------------------------
# 도메인 설정
# ----------------------------------------
# Workspaces 와일드카드 도메인
# 예: workspaces.example.com → *.workspaces.example.com 으로 Workspace가 생성됨
WORKSPACES_DOMAIN="workspaces.example.com"

# Workspaces Proxy 인증 도메인 (OAuth 콜백용)
# 예: workspaces.example.com 설정 시 → auth.workspaces.example.com 으로 자동 생성
# 또는 별도 도메인 지정 가능
WORKSPACES_PROXY_DOMAIN="auth.workspaces.example.com"

# ----------------------------------------
# TLS / cert-manager 설정
# ----------------------------------------
# cert-manager ClusterIssuer 이름
CERT_ISSUER_NAME="letsencrypt-prod"

# Let's Encrypt 인증서 발급용 이메일
LETSENCRYPT_EMAIL="admin@example.com"

# ----------------------------------------
# Ingress 설정
# ----------------------------------------
# Ingress Class 이름 (기본: nginx)
INGRESS_CLASS="nginx"

# ----------------------------------------
# Helm Chart 버전 (GitLab 18.9 호환)
# ----------------------------------------
# cert-manager 버전 (Kubernetes 1.33 호환)
CERT_MANAGER_VERSION="v1.17.2"

# GitLab Agent 차트 버전
# GitLab 인스턴스 버전과 동일하게 맞추는 것을 권장 (±1 마이너 허용)
# 빈 값으로 두면 설치 스크립트에서 GitLab 버전 기준으로 자동 결정
GITLAB_AGENT_CHART_VERSION=""

# GitLab Workspaces Proxy 차트 버전
# 0.1.23 미만 버전은 보안 취약점이 있으므로 반드시 0.1.25 이상 사용
WORKSPACES_PROXY_CHART_VERSION="0.1.25"

# ----------------------------------------
# Workspaces 고급 설정 (선택 사항)
# ----------------------------------------
# 공유 네임스페이스 모드 (GitLab 18.0+)
# "true"로 설정하면 모든 Workspace가 단일 네임스페이스 사용
# "false"로 설정하면 Workspace마다 별도 네임스페이스 생성 (기본값)
WORKSPACES_SHARED_NAMESPACE="false"

# ----------------------------------------
# 리소스 계산 설정 (최대 5,000 동시 사용자)
# ----------------------------------------
# 예상 동시 사용자 수 (Workspace 동시 활성화 기준)
# 이 값에 따라 모든 컴포넌트의 리소스가 자동 계산됩니다.
#
# 티어 기준:
#   XS  : ~50명   (소규모 팀)
#   S   : ~100명  (중소 팀)         ← 기본값
#   M   : ~250명  (중간 규모)
#   L   : ~500명  (대규모 팀)
#   XL  : ~1,000명 (엔터프라이즈)
#   2XL : ~2,500명 (엔터프라이즈 중)
#   3XL : ~5,000명 (엔터프라이즈 대, 멀티 클러스터 권장)
#
# 리소스 계산 실행:
#   bash scripts/resource-calculator.sh ${CONCURRENT_USERS}
CONCURRENT_USERS="100"
