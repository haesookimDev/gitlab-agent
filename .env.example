# ============================================================
# GitLab Workspaces 설치 환경 변수 설정
# 이 파일을 복사하여 .env 파일을 생성하고 값을 채워주세요.
# cp .env.example .env
# ============================================================

# ----------------------------------------
# GitLab 설정
# ----------------------------------------
# GitLab 인스턴스 URL (예: https://gitlab.example.com)
GITLAB_URL="https://gitlab.example.com"

# GitLab Personal Access Token (api, read_repository, write_repository 권한 필요)
GITLAB_TOKEN="glpat-xxxxxxxxxxxxxxxxxxxx"

# GitLab Agent를 등록할 프로젝트 경로 (예: group/project)
GITLAB_PROJECT_PATH="your-group/your-project"

# GitLab Agent 이름 (Kubernetes에서 사용할 이름)
GITLAB_AGENT_NAME="workspaces-agent"

# ----------------------------------------
# Kubernetes 설정
# ----------------------------------------
# GitLab Agent를 설치할 Kubernetes 네임스페이스
GITLAB_AGENT_NAMESPACE="gitlab-agent"

# Workspaces Proxy를 설치할 네임스페이스
WORKSPACES_PROXY_NAMESPACE="gitlab-workspaces"

# Workspaces가 생성될 네임스페이스 (Proxy가 관리)
WORKSPACES_NAMESPACE="gitlab-workspaces"

# ----------------------------------------
# 도메인 및 TLS 설정
# ----------------------------------------
# Workspaces에서 사용할 와일드카드 도메인 (예: *.workspaces.example.com)
WORKSPACES_DOMAIN="workspaces.example.com"

# cert-manager에서 사용할 ClusterIssuer 이름
CERT_ISSUER_NAME="letsencrypt-prod"

# Let's Encrypt 이메일 (TLS 인증서 발급용)
LETSENCRYPT_EMAIL="admin@example.com"

# ----------------------------------------
# Ingress 설정
# ----------------------------------------
# Ingress Class 이름 (예: nginx)
INGRESS_CLASS="nginx"

# ----------------------------------------
# Helm Chart 버전
# ----------------------------------------
CERT_MANAGER_VERSION="v1.14.4"
GITLAB_AGENT_CHART_VERSION="2.4.0"
WORKSPACES_PROXY_CHART_VERSION="0.1.18"
